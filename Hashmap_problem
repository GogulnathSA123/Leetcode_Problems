class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int, int> req_no;
        for(int i =0; i <nums.size(); i++)
        {
            int remaining_no = target - nums[i];
            if(req_no.find(remaining_no) != req_no.end())
            {
                return {req_no[remaining_no], i};
            }
            req_no[nums[i]] = i;
              

            

        }
        return {-1, -1};
    }
};
